# Data files (large, generated, or confidential)
*.rds
*.csv
!mkdata/manual_rules/price_unit_corrections.csv
!mkdata/manual_rules/service_classification_overrides.csv
*.xlsx
*.fst
*.qs
*.parquet
mkdata/raw/

# R package management (renv lockfile IS tracked; library is not)
renv/library/
renv/staging/
renv/cellar/
renv/python/
renv/sandbox/

# R artifacts
.Rhistory
.RData
.Rproj.user
*.Rproj

# Documentation (internal notes, not for public repo)
docs/

# Logs (generated at runtime)
logs/

# Results (generated at runtime)
results/

# PDFs (paper drafts, slides)
*.pdf

# Temporary / scratch files
tmp_*
temp_*
nul
*.tmp

# Smoke / exploratory scripts (local-only, not for shared repo)
# Convention codified in walled_estimate_dynamic_labor/portable_skills/02_project_structure.md.
# Promote by renaming to tests/test_*.R or a numbered analysis script.
# Any file with "smoke" anywhere in the name is local-only.
*smoke*

# Slurm submit scripts (local-only). Use sbatch --wrap or a generic helper
# instead of one .sl per R script.
*.sl

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Machine-specific environment (contains local data paths)
.Renviron
.Renviron.R
.Rprofile

# Local-only scratch / notes (not for public repo)
portable_skills/

# Local archive of superseded scripts (not for public repo)
archive/
