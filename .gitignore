# Data files (large, generated, or confidential)
*.rds
*.csv
*.xlsx
*.fst
*.qs
*.parquet
mkdata/raw/

# R package management (renv lockfile IS tracked; library is not)
renv/library/
renv/staging/
renv/cellar/
renv/python/
renv/sandbox/

# R artifacts
.Rhistory
.RData
.Rproj.user
*.Rproj

# Documentation (internal notes, not for public repo)
docs/

# Logs (generated at runtime)
logs/

# Results (generated at runtime)
results/

# PDFs (paper drafts, slides)
*.pdf

# Temporary / scratch files
tmp_*
temp_*
nul
*.tmp

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Machine-specific environment (contains local data paths)
.Renviron
.Renviron.R
.Rprofile


# Local archive of superseded scripts (not for public repo)
archive/
